<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Styled Table</title>
    <style>
        table {
            border-collapse: collapse;
        }
        td {
            padding: 10px;
            text-align: center;
            color: white;
        }
        .row1 {
            background-color: #ff5733;
        }
        .row2 {
            background-color: #33a1ff;
        }
    </style>
</head>
<body>
    <table border="1">
        <tr>
            <td class="row1">Friend 1</td>
            <td class="row1">Friend 2</td>
        </tr>
        <tr>
            <td class="row2">Friend 3</td>
            <td class="row2">Friend 4</td>
        </tr>
    </table>
</body>
</html>
